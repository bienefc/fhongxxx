# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fhongxxx"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# AWS S3 / Compatible Storage
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="fhongxxx-videos"
# For S3-compatible providers (Cloudflare R2, MinIO, Backblaze B2):
# AWS_ENDPOINT_URL="https://your-endpoint.example.com"

# CDN (optional — serve videos from CDN instead of S3 directly)
CDN_URL="https://cdn.yourdomain.com"

# Redis (for job queue)
REDIS_URL="redis://localhost:6379"

# FFmpeg binary path (if not in $PATH)
# FFMPEG_PATH="/usr/bin/ffmpeg"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FhongXXX"

# Age gate cookie secret
AGE_GATE_SECRET="another-random-secret"

# Cron job secret (used to protect /api/cron/* endpoints)
# Generate with: openssl rand -base64 32
CRON_SECRET="generate-with-openssl-rand-base64-32"
